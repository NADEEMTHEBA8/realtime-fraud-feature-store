# docker-compose interpolates these. All have working local defaults in
# docker-compose.yml, so a .env file is optional for a local run.
POSTGRES_PASSWORD=changeme_local_only
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Read by the host-side Python processes (Spark config, loader, API,
# seed script). Defaults below match the compose services when run from
# the host; override only if you change ports or run elsewhere.
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MINIO_ENDPOINT=http://localhost:9000
PG_HOST=127.0.0.1
PG_PORT=5432
PG_DATABASE=fraud_reference
PG_USER=fraud_admin
PG_PASSWORD=changeme_local_only
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
